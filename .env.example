DJANGO_SECRET_KEY=replace-with-long-random-secret-key
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
DJANGO_USE_HTTPS=true
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.resend.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST_USER=resend
DJANGO_EMAIL_HOST_PASSWORD=replace-with-email-password
DJANGO_DEFAULT_FROM_EMAIL=EnduroBuddy <noreply@mail.endurobuddy.cz>

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_AUTH_RATE_LIMIT_MAX_REQUESTS=30
GOOGLE_AUTH_RATE_LIMIT_WINDOW_SECONDS=300

GARMIN_SYNC_LIMIT=20
GARMIN_KMS_KEY_ID=local-kms-v1
GARMIN_KMS_KEYS=replace-with-urlsafe-base64-fernet-key

POSTGRES_DB=replace-with-postgres-db
POSTGRES_USER=replace-with-postgres-user
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

TRAEFIK_HOST=your-domain.com
TRAEFIK_CERTRESOLVER=letsencrypt
