DJANGO_SECRET_KEY=replace-with-long-random-secret-key
DJANGO_DEBUG=false
DJANGO_USE_HTTPS=true
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=EnduroBuddy <noreply@mail.endurobuddy.cz>
DJANGO_EMAIL_HOST=smtp.resend.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST_USER=resend
DJANGO_EMAIL_HOST_PASSWORD=replace-with-resend-api-key

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_AUTH_RATE_LIMIT_MAX_REQUESTS=30
GOOGLE_AUTH_RATE_LIMIT_WINDOW_SECONDS=300

GARMIN_SYNC_LIMIT=20
GARMIN_KMS_KEY_ID=replace-with-kms-key-id
GARMIN_KMS_KEYS=replace-with-urlsafe-base64-fernet-key
GARMIN_CONNECT_ENABLED=true
GARMIN_SYNC_ENABLED=true

POSTGRES_DB=replace-with-db-name
POSTGRES_USER=replace-with-db-user
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

TRAEFIK_HOST=endurobuddy.cz
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_APP_HOST=app.endurobuddy.cz

# Dev: leave empty (no Domain attribute on cookies — required for localhost to work)
# Prod: set to .endurobuddy.cz (leading dot = shared across subdomains)
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=
# Dev: leave empty (no cross-domain redirects after login)
# Prod: set to app.endurobuddy.cz
DJANGO_APP_HOST=
DJANGO_ALLOWED_HOSTS=endurobuddy.cz,app.endurobuddy.cz,www.endurobuddy.cz
DJANGO_CSRF_TRUSTED_ORIGINS=https://endurobuddy.cz,https://app.endurobuddy.cz,https://www.endurobuddy.cz
DJANGO_CORS_ALLOWED_ORIGINS=https://endurobuddy.cz,https://app.endurobuddy.cz,http://localhost

REGISTRATION_ENABLED=true
