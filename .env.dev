# ─────────────────────────────────────────────────────────────────────────────
# EnduroBuddy — Local dev defaults
# Usage:
#   cp .env.dev .env
#   echo "NUXT_PUBLIC_APP_HOST=app.lvh.me" > frontend/.env   # native Nuxt dev only
#
# Docker dev overrides (docker-compose.yml environment block takes precedence):
#   POSTGRES_HOST → db
#   REDIS_URL     → redis://redis:6379/0
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=dev-insecure-secret-do-not-use-in-production
DJANGO_DEBUG=true
DJANGO_USE_HTTPS=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=EnduroBuddy <noreply@endurobuddy.local>
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=

# ── Google OAuth (optional — leave empty to disable) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_RATE_LIMIT_MAX_REQUESTS=30
GOOGLE_AUTH_RATE_LIMIT_WINDOW_SECONDS=300

# ── Garmin (disabled by default in dev) ───────────────────────────────────────
GARMIN_SYNC_LIMIT=20
GARMIN_KMS_KEY_ID=local-kms-v1
GARMIN_KMS_KEYS=
GARMIN_CONNECT_ENABLED=false
GARMIN_SYNC_ENABLED=false

# ── Postgres ──────────────────────────────────────────────────────────────────
# Native dev: Docker exposes :5432 on 127.0.0.1
# Docker dev: POSTGRES_HOST overridden to "db" in docker-compose.yml
POSTGRES_DB=endurobuddy
POSTGRES_USER=endurobuddy
POSTGRES_PASSWORD=endurobuddy_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
# Native dev: Docker exposes :6379 on 127.0.0.1
# Docker dev: REDIS_URL overridden to redis://redis:6379/0 in docker-compose.yml
REDIS_URL=redis://127.0.0.1:6379/0

# ── Domains — lvh.me a všechny subdomény resolvují na 127.0.0.1 ───────────────
# Veřejná část:  http://lvh.me:3000
# Přihlášená:    http://app.lvh.me:3000
DJANGO_APP_HOST=app.lvh.me
SESSION_COOKIE_DOMAIN=.lvh.me
CSRF_COOKIE_DOMAIN=.lvh.me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,lvh.me,app.lvh.me
DJANGO_CSRF_TRUSTED_ORIGINS=http://lvh.me:3000,http://app.lvh.me:3000,http://lvh.me:8000,http://app.lvh.me:8000
DJANGO_CORS_ALLOWED_ORIGINS=http://lvh.me:3000,http://app.lvh.me:3000

# ── Nuxt ──────────────────────────────────────────────────────────────────────
# Docker dev: předáno do nuxt kontejneru přes docker-compose.yml
# Native dev: musí být také v frontend/.env
NUXT_PUBLIC_APP_HOST=app.lvh.me

# ── Misc ──────────────────────────────────────────────────────────────────────
REGISTRATION_ENABLED=true
